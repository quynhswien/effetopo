<Window
    x:Class="effetopo.Views.FloorBoundarySamplingDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen"
    Title="Boundary Point Division"
    Height="580"
    Width="680"
    MinHeight="520"
    MinWidth="560">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Text="Divide Boundary Points Along Curves"/>
        <TextBlock Grid.Row="1" Margin="0,8,0,16" TextWrapping="Wrap">
            Choose how to add elevation points along each floor boundary line or arc.
            Corner junction points are handled separately.
        </TextBlock>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <RadioButton x:Name="DistanceModeOption" GroupName="SampleMode" IsChecked="True" Margin="0,0,0,8"
                         Content="By distance — spacing between points along each curve"/>
            <Border Margin="20,0,0,12" Padding="12" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4">
                <StackPanel x:Name="DistancePanel">
                    <RadioButton x:Name="DistPreset1" GroupName="DistanceOptions" IsChecked="True" Margin="0,4,0,0"/>
                    <RadioButton x:Name="DistPreset2" GroupName="DistanceOptions" Margin="0,6,0,0"/>
                    <RadioButton x:Name="DistPreset3" GroupName="DistanceOptions" Margin="0,6,0,0"/>
                    <StackPanel Margin="0,8,0,4">
                        <RadioButton x:Name="DistCustomOption" GroupName="DistanceOptions" Content="Custom spacing"/>
                        <DockPanel Margin="24,6,0,0" LastChildFill="False">
                            <TextBox x:Name="DistCustomTextBox" Width="220" Height="28" IsEnabled="False" VerticalContentAlignment="Center"/>
                            <TextBlock x:Name="DistUnitText" Margin="10,4,0,0" VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <RadioButton x:Name="CountModeOption" GroupName="SampleMode" Margin="0,4,0,8"
                         Content="By number — equal segments per curve"/>
            <Border Margin="20,0,0,8" Padding="12" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4">
                <StackPanel x:Name="CountPanel" IsEnabled="False">
                    <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,8"
                               Text="Each curve is split into N equal segments (N + 1 sample positions, including endpoints)."/>
                    <RadioButton x:Name="CountPreset1" GroupName="CountOptions" IsChecked="True" Margin="0,4,0,0"/>
                    <RadioButton x:Name="CountPreset2" GroupName="CountOptions" Margin="0,6,0,0"/>
                    <RadioButton x:Name="CountPreset3" GroupName="CountOptions" Margin="0,6,0,0"/>
                    <StackPanel Margin="0,8,0,4">
                        <RadioButton x:Name="CountCustomOption" GroupName="CountOptions" Content="Custom segment count"/>
                        <DockPanel Margin="24,6,0,0" LastChildFill="False">
                            <TextBox x:Name="CountCustomTextBox" Width="220" Height="28" IsEnabled="False" VerticalContentAlignment="Center"/>
                            <TextBlock Margin="10,4,0,0" VerticalAlignment="Center" Text="segments"/>
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Width="90" Margin="0,0,10,0" IsDefault="True" Click="Ok_Click">OK</Button>
            <Button Width="90" IsCancel="True" Click="Cancel_Click">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>
