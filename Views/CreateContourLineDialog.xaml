<Window
    x:Class="effetopo.Views.CreateContourLineDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen"
    Title="Create Contour Line"
    Height="560"
    Width="540"
    MinHeight="520"
    MinWidth="480">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Text="Create Contour Line"/>
        <TextBlock Grid.Row="0" Margin="0,28,0,16" TextWrapping="Wrap" Foreground="#555"
                   Text="Generate model lines along contour elevations sampled from the selected Toposolid surface."/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <DockPanel Margin="0,0,0,12" LastChildFill="True">
                    <TextBlock Width="150" VerticalAlignment="Center" Text="Contour Interval"/>
                    <TextBox x:Name="IntervalTextBox" Height="28" VerticalContentAlignment="Center" Text="1"/>
                    <TextBlock x:Name="IntervalUnitText" Width="40" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </DockPanel>

                <CheckBox x:Name="UseMajorMinorCheckBox" Margin="0,0,0,12"
                          Content="Use Major / Minor Contours"/>

                <DockPanel x:Name="MajorIntervalPanel" Margin="0,0,0,12" LastChildFill="True">
                    <TextBlock Width="150" VerticalAlignment="Center" Text="Major Interval"/>
                    <TextBox x:Name="MajorIntervalTextBox" Height="28" VerticalContentAlignment="Center" Text="5"/>
                    <TextBlock x:Name="MajorIntervalUnitText" Width="40" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </DockPanel>

                <DockPanel Margin="0,0,0,12" LastChildFill="True">
                    <TextBlock Width="150" VerticalAlignment="Center" Text="Minor Line Style"/>
                    <ComboBox x:Name="MinorLineStyleCombo" Height="28"
                              DisplayMemberPath="DisplayName" SelectedValuePath="Name"/>
                </DockPanel>

                <DockPanel x:Name="MajorLineStylePanel" Margin="0,0,0,12" LastChildFill="True">
                    <TextBlock Width="150" VerticalAlignment="Center" Text="Major Line Style"/>
                    <ComboBox x:Name="MajorLineStyleCombo" Height="28"
                              DisplayMemberPath="DisplayName" SelectedValuePath="Name"/>
                </DockPanel>

                <CheckBox x:Name="AssignLevelCheckBox" Margin="0,0,0,12"
                          Content="Assign Reference Level"/>

                <DockPanel x:Name="LevelPanel" Margin="0,0,0,12" LastChildFill="True">
                    <TextBlock Width="150" VerticalAlignment="Center" Text="Level"/>
                    <ComboBox x:Name="LevelCombo" Height="28"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                </DockPanel>

                <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="12"
                           Text="Contour and major intervals default from the Toposolid when available. Minor contours use the contour interval; major contours occur at multiples of the major interval."/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Width="90" Margin="0,0,10,0" IsDefault="True" Click="Ok_Click">OK</Button>
            <Button Width="90" IsCancel="True" Click="Cancel_Click">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>
