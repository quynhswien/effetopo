<Window x:Class="effetopo.Views.LicenseActivationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:effetopo.Views.Converters"
        Title="License Activation" Height="300" Width="500" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="License Activation" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,10">
            Enter your license key to activate this product. If you don't have a license key, please contact your administrator.
        </TextBlock>
        
        <TextBlock Grid.Row="2" Text="License Key:" Margin="0,10,0,5"/>
        <TextBox Grid.Row="3" x:Name="LicenseKeyTextBox" Height="30" Padding="5" Margin="0,0,0,10" 
                 Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"/>
        
        <StackPanel Grid.Row="4" VerticalAlignment="Center">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="{Binding StatusColor}" 
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
            <ProgressBar IsIndeterminate="True" Height="5" Margin="0,10" 
                         Visibility="{Binding IsActivating, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
        
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="1" Content="Activate" Width="100" Height="30" Margin="0,0,10,0" 
                    Command="{Binding ActivateCommand}"/>
            <Button Grid.Column="2" Content="Cancel" Width="100" Height="30" 
                    Command="{Binding CancelCommand}" IsCancel="True"/>
        </Grid>
    </Grid>
</Window> 