<Window
    x:Class="effetopo.Views.ModifyTopoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen"
    Title="Modify Toposolid"
    Height="720"
    Width="920"
    MinHeight="640"
    MinWidth="800"
    Background="#F5F5F5">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Text="Modify Toposolid" Margin="4,0,0,8"/>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Topography Data -->
            <Border Grid.Column="0" Margin="0,0,12,0" Padding="14" Background="White"
                    BorderBrush="#C8C8C8" BorderThickness="1" CornerRadius="2">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" FontSize="14" Text="Topography Data" Margin="0,0,0,12"/>
                    <TextBlock Text="Original amount of points:" Foreground="#555"/>
                    <TextBlock x:Name="OriginalPointsText" FontSize="22" FontWeight="Bold" Margin="0,2,0,12"/>
                    <TextBlock Text="Points after modification:" Foreground="#555"/>
                    <TextBlock x:Name="ModifiedPointsText" FontSize="22" FontWeight="Bold" Foreground="#C0392B" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Tools + settings -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tool buttons -->
                <UniformGrid Grid.Row="0" Rows="1" Columns="4" Margin="0,0,0,10">
                    <ToggleButton x:Name="InflateToolBtn" Margin="4" Padding="8" Height="100"
                                  Click="ToolButton_Click" Tag="InflateSurface">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⬆" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Inflate Surface" FontWeight="SemiBold" TextAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="MeshToolBtn" Margin="4" Padding="8" Height="100"
                                  Click="ToolButton_Click" Tag="MeshControl">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="▦" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Mesh Control" FontWeight="SemiBold" TextAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="ShapeToolBtn" Margin="4" Padding="8" Height="100"
                                  Click="ToolButton_Click" Tag="ShapeByPoint">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="◎" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Shape by Point" FontWeight="SemiBold" TextAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="SmoothToolBtn" Margin="4" Padding="8" Height="100"
                                  Click="ToolButton_Click" Tag="SmoothGeometry">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="∿" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Smooth Geometry" FontWeight="SemiBold" TextAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </ToggleButton>
                </UniformGrid>

                <!-- Tool-specific panels -->
                <Border Grid.Row="1" Padding="14" Background="White" BorderBrush="#C8C8C8" BorderThickness="1" CornerRadius="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Inflate Surface -->
                            <StackPanel x:Name="InflatePanel" Visibility="Collapsed">
                                <TextBlock Text="Push or pull surface along vertical normal with soft falloff (brush-style sculpt)."
                                           TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Radius:"/>
                                    <TextBox x:Name="InflateRadiusBox" Grid.Row="0" Grid.Column="1" Height="28" Margin="0,4"/>
                                    <TextBlock x:Name="InflateRadiusUnit" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Inflate Height:"/>
                                    <TextBox x:Name="InflateHeightBox" Grid.Row="1" Grid.Column="1" Height="28" Margin="0,4"/>
                                    <TextBlock x:Name="InflateHeightUnit" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Falloff:"/>
                                    <ComboBox x:Name="InflateFalloffCombo" Grid.Row="2" Grid.Column="1" Height="28" Margin="0,4"/>
                                </Grid>
                                <TextBlock Margin="0,10,0,0" Foreground="#777" TextWrapping="Wrap"
                                           Text="Use + height to raise (berm, mound) or − to depress (pond, grading cut). Pick center point after Apply."/>
                            </StackPanel>

                            <!-- Mesh Control -->
                            <StackPanel x:Name="MeshPanel" Visibility="Collapsed">
                                <TextBlock Text="Adaptive remeshing: denser triangles in curved areas, larger in flat zones."
                                           TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"/>
                                <CheckBox x:Name="RemeshEntireCheck" Content="Remesh entire surface" IsChecked="True" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Curvature threshold:"/>
                                    <TextBox x:Name="CurvatureThresholdBox" Grid.Column="1" Height="28" Margin="0,4"/>
                                </Grid>
                                <TextBlock Margin="0,8,0,0" Foreground="#777" TextWrapping="Wrap"
                                           Text="Uses Cell Size for flat areas and Mesh Density for curved regions. No point pick required."/>
                            </StackPanel>

                            <!-- Shape by Point -->
                            <StackPanel x:Name="ShapePanel" Visibility="Collapsed">
                                <TextBlock Text="Place a radial elevation stamp on the toposolid surface via Modify Sub Elements."
                                           TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Gain Value:"/>
                                    <TextBox x:Name="ShapeDeltaBox" Grid.Row="0" Grid.Column="1" Height="28" Margin="0,4"/>
                                    <TextBlock x:Name="ShapeDeltaUnit" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Shape Size:"/>
                                    <TextBox x:Name="ShapeRadiusBox" Grid.Row="1" Grid.Column="1" Height="28" Margin="0,4"/>
                                    <TextBlock x:Name="ShapeRadiusUnit" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Point Density:"/>
                                    <Slider x:Name="ShapePointDensitySlider" Grid.Row="2" Grid.Column="1"
                                            Minimum="1" Maximum="10" Value="5" TickFrequency="1"
                                            IsSnapToTickEnabled="True" Margin="0,8"/>
                                    <TextBlock x:Name="ShapePointDensityText" Grid.Row="2" Grid.Column="2"
                                               VerticalAlignment="Center" Margin="8,0,0,0" Text="5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Falloff:"/>
                                    <ComboBox x:Name="ShapeFalloffCombo" Grid.Row="3" Grid.Column="1" Height="28" Margin="0,4"/>
                                </Grid>
                                <TextBlock Margin="0,10,0,0" Foreground="#777" TextWrapping="Wrap"
                                           Text="Bấm «Pick &amp; Preview Stamp» để thêm stamp vào draft (cam/orange trên topo). Có thể lặp nhiều lần. Bấm Ok để ghi thật vào Toposolid; Cancel bỏ hết draft."/>
                            </StackPanel>

                            <!-- Smooth Geometry -->
                            <StackPanel x:Name="SmoothPanel" Visibility="Collapsed">
                                <TextBlock Text="Remove sharp vertices and noise without changing overall design intent."
                                           TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Algorithm:"/>
                                    <ComboBox x:Name="SmoothAlgoCombo" Grid.Row="0" Grid.Column="1" Height="28" Margin="0,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Iterations:"/>
                                    <TextBox x:Name="SmoothIterationsBox" Grid.Row="1" Grid.Column="1" Height="28" Margin="0,4"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Strength (0–1):"/>
                                    <Slider x:Name="SmoothStrengthSlider" Grid.Row="2" Grid.Column="1"
                                            Minimum="0.05" Maximum="1" Value="0.5" TickFrequency="0.05"
                                            IsSnapToTickEnabled="True" Margin="0,8"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Point Grid Settings -->
        <Border x:Name="PointGridSettingsBorder" Grid.Row="2" Margin="0,12,0,0" Padding="14" Background="White"
                BorderBrush="#C8C8C8" BorderThickness="1" CornerRadius="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="PointGridSettingsPanel" Grid.Column="0">
                    <TextBlock FontWeight="SemiBold" Text="Point Grid Settings" Margin="0,0,0,8"/>
                    <DockPanel Margin="0,4">
                        <TextBlock DockPanel.Dock="Left" Width="90" VerticalAlignment="Center" Text="Cell Size:"/>
                        <TextBox x:Name="CellSizeBox" Width="100" Height="28"/>
                        <TextBlock x:Name="CellSizeUnit" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                    <DockPanel Margin="0,8">
                        <TextBlock DockPanel.Dock="Left" Width="90" VerticalAlignment="Center" Text="Rotation:"/>
                        <Slider x:Name="RotationSlider" Minimum="0" Maximum="360" Value="0" Width="200"/>
                        <TextBlock x:Name="RotationValueText" Margin="8,0,0,0" VerticalAlignment="Center" Text="0°"/>
                    </DockPanel>
                </StackPanel>
                <StackPanel x:Name="MeshDensityPanel" Grid.Column="1" Margin="24,0,0,0">
                    <TextBlock FontWeight="SemiBold" Text="Mesh Density" Margin="0,0,0,8"/>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Width="100" VerticalAlignment="Center" Text="Mesh Density:"/>
                        <TextBox x:Name="MeshDensityBox" Width="100" Height="28"/>
                        <TextBlock x:Name="MeshDensityUnit" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                    <CheckBox x:Name="ModifyBoundaryCheck" Content="Modify Boundary" Margin="0,12,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Orientation="Horizontal">
                    <Button x:Name="UndoBtn" Content="↶" Width="36" Height="32" Margin="0,0,6,0"
                            ToolTip="Undo (last operation)" Click="Undo_Click" IsEnabled="False"/>
                    <Button x:Name="RedoBtn" Content="↷" Width="36" Height="32"
                            ToolTip="Redo" Click="Redo_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer buttons -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="ShowPreviewCheck" Content="Show Preview" VerticalAlignment="Center" IsChecked="True"
                      ToolTip="Shape by Point: hiển thị draft stamp (cam) trên topo. Ok mới commit thật."/>
            <TextBlock x:Name="PreviewStatusText" Grid.Column="0" Margin="140,0,0,0"
                       VerticalAlignment="Center" Foreground="#666" FontSize="11"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="PickApplyBtn" Content="Pick &amp; Preview Stamp" Width="160" Height="32" Margin="0,0,8,0"
                        Visibility="Collapsed" Click="PickApply_Click"
                        ToolTip="Chọn điểm để thêm stamp vào draft (preview). Ok để ghi vào Toposolid."/>
                <Button x:Name="ApplyBtn" Content="Apply changes" Width="120" Height="32" Margin="0,0,8,0"
                        Click="Apply_Click"/>
                <Button Content="Cancel" Width="90" Height="32" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
                <Button Content="Ok" Width="90" Height="32" IsDefault="True" Click="Ok_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
